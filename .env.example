# Cortex-AI Environment Configuration
# Copy this file to .env and fill in your values

# ============================================================================
# Application
# ============================================================================
APP_NAME=cortex-ai
APP_ENV=development  # development, staging, production
DEBUG=true
LOG_LEVEL=INFO  # DEBUG, INFO, WARNING, ERROR, CRITICAL

# API Server
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=4

# Security
SECRET_KEY=your-secret-key-change-this-in-production
API_KEY_SALT=your-api-key-salt-change-this
ALLOWED_HOSTS=localhost,127.0.0.1

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:8080
CORS_ALLOW_CREDENTIALS=true

# ============================================================================
# Database (PostgreSQL)
# ============================================================================
DATABASE_URL=postgresql://cortex:cortex_dev_password@localhost:5432/cortex
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10
DATABASE_ECHO=false

# ============================================================================
# Redis (Cache & Sessions)
# ============================================================================
REDIS_URL=redis://localhost:6379/0
REDIS_MAX_CONNECTIONS=50
REDIS_SOCKET_TIMEOUT=5
REDIS_SOCKET_CONNECT_TIMEOUT=5

# Cache TTL (seconds)
CACHE_TTL_EMBEDDINGS=3600
CACHE_TTL_SEARCH=300
CACHE_TTL_SESSION=86400

# ============================================================================
# Qdrant (Vector Database)
# ============================================================================
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=  # Optional, leave empty for local dev
QDRANT_TIMEOUT=30
QDRANT_PREFER_GRPC=false

# Vector search settings
QDRANT_COLLECTION_NAME=cortex_documents
QDRANT_EMBEDDING_DIMENSIONS=1536
QDRANT_DISTANCE_METRIC=Cosine  # Cosine, Euclid, Dot, Manhattan
QDRANT_ENABLE_HYBRID=true
QDRANT_DENSE_VECTOR_NAME=dense
QDRANT_BM25_VECTOR_NAME=sparse

# ============================================================================
# Neo4j (Graph Database for GraphRAG)
# ============================================================================
CORTEX_NEO4J_URL=bolt://localhost:7687
CORTEX_NEO4J_USER=neo4j
CORTEX_NEO4J_PASSWORD=cortex_neo4j_password
CORTEX_NEO4J_DATABASE=neo4j  # Default database
CORTEX_NEO4J_MAX_CONNECTION_POOL_SIZE=50
CORTEX_NEO4J_CONNECTION_TIMEOUT=30

# GraphRAG settings
CORTEX_GRAPHRAG_ENABLED=true
CORTEX_AUTO_EXTRACT_ENTITIES=true
CORTEX_ENTITY_EXTRACTION_MODEL=gpt-4o-mini  # Cheaper model for extraction

# ============================================================================
# LLM Providers
# ============================================================================

# Anthropic (Claude)
ANTHROPIC_API_KEY=your-anthropic-api-key
ANTHROPIC_DEFAULT_MODEL=claude-sonnet-4
ANTHROPIC_MAX_TOKENS=4096
ANTHROPIC_TEMPERATURE=0.7

# OpenAI
OPENAI_API_KEY=your-openai-api-key
OPENAI_DEFAULT_MODEL=gpt-4o
OPENAI_MAX_TOKENS=4096
OPENAI_TEMPERATURE=0.7

# OpenAI Embeddings
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=1536
EMBEDDING_BATCH_SIZE=100

# Google Vertex AI (optional)
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_CLOUD_LOCATION=us-central1
GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json
VERTEX_AI_MODEL=gemini-pro

# ============================================================================
# MCP (Model Context Protocol)
# ============================================================================
MCP_SERVER_URL=http://localhost:8001
MCP_TIMEOUT=30
MCP_MAX_RETRIES=3

# ============================================================================
# Agent Configuration
# ============================================================================
AGENT_DEFAULT_PROVIDER=anthropic  # anthropic, openai, vertex
AGENT_DEFAULT_MODEL=claude-sonnet-4
AGENT_MAX_ITERATIONS=10
AGENT_STREAM_ENABLED=true

# Conversation settings
MAX_CONVERSATION_HISTORY=50
CONVERSATION_SUMMARY_THRESHOLD=20

# ============================================================================
# RAG Configuration
# ============================================================================
# Traditional RAG (Vector Search)
RAG_TOP_K=5
RAG_MIN_SCORE=0.7
RAG_RERANK_ENABLED=false
RAG_HYBRID_ALPHA=0.5  # 0.0 = pure keyword, 1.0 = pure vector

# GraphRAG (Knowledge Graph + Vector Search)
# Note: Requires CORTEX_GRAPHRAG_ENABLED=true and Neo4j running
GRAPHRAG_USE_GRAPH_TRAVERSAL=true
GRAPHRAG_MAX_HOPS=2  # Maximum relationship hops in graph traversal
GRAPHRAG_GRAPH_WEIGHT=0.3  # Weight for graph results (0.0-1.0)

# Document processing
MAX_DOCUMENT_SIZE_MB=10
CHUNK_SIZE=1000
CHUNK_OVERLAP=200
SUPPORTED_DOCUMENT_TYPES=txt,md,pdf,html

# ============================================================================
# Observability
# ============================================================================

# Prometheus
PROMETHEUS_ENABLED=false
PROMETHEUS_PORT=9090

# OpenTelemetry
OTEL_ENABLED=false
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_SERVICE_NAME=cortex-ai
OTEL_TRACES_SAMPLER=parentbased_traceidratio
OTEL_TRACES_SAMPLER_ARG=0.1

# Logging
LOG_FORMAT=json  # json, text
LOG_FILE=/var/log/cortex/app.log
LOG_ROTATION=daily
LOG_RETENTION_DAYS=30

# ============================================================================
# Rate Limiting
# ============================================================================
RATE_LIMIT_ENABLED=true
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_PER_HOUR=1000

# ============================================================================
# Background Tasks
# ============================================================================
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2
CELERY_TASK_ALWAYS_EAGER=false

# ============================================================================
# Feature Flags
# ============================================================================
FEATURE_MULTI_AGENT=true  # Multi-agent swarm coordination
FEATURE_GRAPHRAG=true  # GraphRAG with Neo4j knowledge graphs
FEATURE_ANALYTICS=false  # StarRocks OLAP (future)
FEATURE_STREAMING=true  # SSE streaming responses
FEATURE_MCP=true  # Model Context Protocol

# ============================================================================
# Development
# ============================================================================
# Hot reload
RELOAD=true

# Debug toolbar
DEBUG_TOOLBAR=false

# Test mode
TEST_MODE=false
